      { label: 'BSN Capstone',          href: '/bsn-capstone-project-help/' },
      { label: 'MSN Capstone',          href: '/msn-capstone-project-help/' },
    ],
  },
  {
    label: 'By University',
    children: [
      { label: 'Grand Canyon University', href: '/dnp-capstone-project-help-grand-canyon-university/' },
      { label: 'Walden University',       href: '/walden-university-dnp-capstone-help/' },
      { label: 'Capella University',      href: '/capella-dnp-capstone-help/' },
      { label: 'Aspen University',        href: '/dnp-capstone-project-help-aspen-university/' },
