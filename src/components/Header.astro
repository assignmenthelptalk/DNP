      { label: 'PMHNP Capstone',        href: '/dnp-pmhnp-capstone-help/' },
      { label: 'AGACNP Capstone',       href: '/dnp-agacnp-capstone-help/' },
      { label: 'CRNA Capstone',         href: '/dnp-crna-capstone-help/' },
      { label: 'Nurse Executive',       href: '/dnp-nurse-executive-capstone-help/' },
