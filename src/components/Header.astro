---
const WA_NUMBER  = "447916696894";
const WA_HREF    = `https://wa.me/${WA_NUMBER}`;
const WA_DISPLAY = "+44 7916 696894";

interface DropdownItem { label: string; href: string; }
interface NavItem {
  label: string;
  href?: string;
  children?: DropdownItem[];
}
interface Props {
  logoText:  string;
  logoHref:  string;
  ctaButton: { label: string; href: string; };
  /** Legacy prop — kept for compatibility but nav is now defined below */
  navLinks?: unknown[];
}

const { logoText, logoHref, ctaButton } = Astro.props;

const NAV: NavItem[] = [
  {
    label: 'Services',
    children: [
      { label: 'DNP Capstone Help',     href: '/dnp-capstone-project-help/' },
      { label: 'PICOT Question Help',   href: '/dnp-picot-question-help/' },
      { label: 'Capstone Proposal',     href: '/dnp-capstone-proposal-help/' },
      { label: 'Literature Review',     href: '/dnp-literature-review-help/' },
      { label: 'IRB Proposal Help',     href: '/dnp-irb-proposal-help/' },
      { label: 'Implementation Plan',   href: '/dnp-implementation-plan-help/' },
      { label: 'Data Analysis',         href: '/dnp-data-analysis-help/' },
      { label: 'Manuscript Help',       href: '/dnp-capstone-manuscript-help/' },
      { label: 'PowerPoint Help',       href: '/dnp-powerpoint-presentation-help/' },
      { label: 'Discussion Board Help', href: '/dnp-discussion-board-help/' },
