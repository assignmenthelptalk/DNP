      { label: '50 Project Ideas',      href: '/50-dnp-capstone-project-ideas/' },
      { label: '60 PICOT Examples',     href: '/60-dnp-picot-question-examples/' },
      { label: 'Project Examples',      href: '/dnp-capstone-project-examples/' },
      { label: 'DNP vs PhD',            href: '/dnp-vs-phd-nursing/' },
      { label: 'AACN Essentials 2021',  href: '/aacn-dnp-essentials-2021/' },
      { label: 'EBP Frameworks',        href: '/ebp-frameworks-dnp/' },
      { label: 'Statistical Methods',   href: '/statistical-methods-dnp/' },
      { label: 'IRB Protocol',          href: '/irb-protocol-dnp/' },
    ],
