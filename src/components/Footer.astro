---
const EMAIL    = "Assignmenthelptalk@gmail.com";
const WA_HREF  = "https://wa.me/447916696894";
const WA_LABEL = "+44 7916 696894";
const YEAR     = new Date().getFullYear();

interface Props {
  /** Accepted for backward-compat but nav is self-contained below */
  logoText?:    string;
  description?: string;
  columns?:     unknown[];
  copyright?:   string;
}
---

<!-- Organization JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "DNP Capstone Project Help",
  "url": "https://dnpcapstoneproject.help",
  "logo": "https://dnpcapstoneproject.help/favicon.svg",
  "email": EMAIL,
  "telephone": "+447916696894",
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+447916696894",
    "contactType": "customer support",
    "availableLanguage": "English"
  },
  "sameAs": [WA_HREF]
})} />

<footer class="footer" aria-label="Site footer">

  <!-- Main link grid -->
  <div class="footer__top">
    <div class="container footer__grid">

      <!-- Brand + contact -->
      <div class="footer__brand">
        <a href="/" class="footer__logo">DNP Help</a>
        <p class="footer__desc">
          The trusted specialist in Doctor of Nursing Practice capstone project support.
          Helping DNP students across all specialisations complete proposals, IRB submissions,
          literature reviews, and final manuscripts — on time and to committee standard.
        </p>
        <ul class="footer__contact">
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
