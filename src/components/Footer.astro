        </ul>
        <div class="footer__badges">
          <span class="footer__badge">PhD &amp; DNP Writers</span>
          <span class="footer__badge">100% Original</span>
          <span class="footer__badge">On-Time Guarantee</span>
          <span class="footer__badge">Confidential</span>
        </div>
      </div>

      <!-- DNP Services -->
      <div class="footer__col">
        <h3 class="footer__col-heading">DNP Services</h3>
        <ul class="footer__links">
          <li><a href="/dnp-capstone-project-help/" class="footer__link">DNP Capstone Project Help</a></li>
          <li><a href="/dnp-capstone-proposal-help/" class="footer__link">DNP Capstone Proposal Help</a></li>
          <li><a href="/dnp-picot-question-help/" class="footer__link">DNP PICOT Question Help</a></li>
          <li><a href="/dnp-literature-review-help/" class="footer__link">DNP Literature Review Help</a></li>
          <li><a href="/dnp-irb-proposal-help/" class="footer__link">DNP IRB Proposal Help</a></li>
