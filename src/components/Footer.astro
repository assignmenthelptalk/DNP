</footer>

<style>
  .footer {
    background-color: var(--color-bg-dark, #0b1f2e);
    color: var(--color-white, #fff);
  }

  /* ── Main grid ──────────────────────────────────────────────── */
  .footer__top {
    padding: 3.5rem 0 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr;
    gap: 2.5rem;
    align-items: start;
  }

  /* ── Brand column ───────────────────────────────────────────── */
  .footer__logo {
    display: inline-block;
    font-size: 1.375rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    margin-bottom: 0.875rem;
  }

  .footer__desc {
    font-size: 0.9rem;
    color: rgba(255,255,255,0.62);
    line-height: 1.75;
    max-width: 300px;
    margin-bottom: 1.25rem;
  }

  .footer__contact {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .footer__contact li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255,255,255,0.6);
    font-size: 0.875rem;
  }

  .footer__contact li svg { flex-shrink: 0; color: var(--color-accent, #e67e22); }

  .footer__contact-link {
    color: rgba(255,255,255,0.75);
    transition: color 0.15s;
    word-break: break-all;
  }

  .footer__contact-link:hover { color: var(--color-accent, #e67e22); }

  .footer__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .footer__badge {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.6rem;
    border-radius: 2rem;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(255,255,255,0.7);
    white-space: nowrap;
  }

  /* ── Link columns ───────────────────────────────────────────── */
  .footer__col-heading {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.45);
    margin-bottom: 0.875rem;
  }

  .footer__col-heading--spaced { margin-top: 1.75rem; }

  .footer__links {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .footer__link {
    font-size: 0.875rem;
    color: rgba(255,255,255,0.7);
    transition: color 0.15s;
    line-height: 1.4;
  }

  .footer__link:hover { color: var(--color-accent, #e67e22); }

  /* ── Trust bar ──────────────────────────────────────────────── */
  .footer__trust {
    background: rgba(255,255,255,0.04);
    border-bottom: 1px solid rgba(255,255,255,0.07);
    padding: 1rem 0;
  }

  .footer__trust-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem 1.5rem;
  }

  .footer__trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: rgba(255,255,255,0.55);
    white-space: nowrap;
  }

  .footer__trust-item svg { color: var(--color-accent, #e67e22); flex-shrink: 0; }

  /* ── Bottom bar ─────────────────────────────────────────────── */
  .footer__bar { padding: 1rem 0; }

  .footer__bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.35);
  }

  .footer__legal-nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .footer__legal-link {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.35);
    transition: color 0.15s;
    white-space: nowrap;
  }

  .footer__legal-link:hover { color: rgba(255,255,255,0.7); }

  /* ── Responsive ─────────────────────────────────────────────── */
  @media (max-width: 1200px) {
    .footer__grid { grid-template-columns: 1fr 1fr 1fr 1fr; }
    .footer__brand { grid-column: 1 / -1; }
    .footer__desc { max-width: 100%; }
    .footer__badges { flex-direction: row; }
  }

  @media (max-width: 768px) {
    .footer__grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .footer__trust-inner { justify-content: flex-start; }
  }

  @media (max-width: 480px) {
    .footer__grid { grid-template-columns: 1fr; }
    .footer__bar-inner { flex-direction: column; align-items: flex-start; }
    .footer__trust-item { font-size: 0.75rem; }
  }
</style>
