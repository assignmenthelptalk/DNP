          <li><a href="/dnp-discussion-board-help/" class="footer__link">DNP Discussion Board Help</a></li>
        </ul>
      </div>

      <!-- By Specialty -->
      <div class="footer__col">
        <h3 class="footer__col-heading">By Specialty</h3>
        <ul class="footer__links">
          <li><a href="/dnp-fnp-capstone-help/" class="footer__link">FNP DNP Capstone Help</a></li>
          <li><a href="/dnp-pmhnp-capstone-help/" class="footer__link">PMHNP DNP Capstone Help</a></li>
          <li><a href="/dnp-agacnp-capstone-help/" class="footer__link">AGACNP DNP Capstone Help</a></li>
          <li><a href="/dnp-crna-capstone-help/" class="footer__link">CRNA DNP Capstone Help</a></li>
          <li><a href="/dnp-nurse-executive-capstone-help/" class="footer__link">Nurse Executive DNP Capstone</a></li>
          <li><a href="/dnp-population-health-capstone-help/" class="footer__link">Population Health DNP Capstone</a></li>
          <li><a href="/dnp-nursing-informatics-capstone-help/" class="footer__link">Nursing Informatics DNP Capstone</a></li>
          <li><a href="/bsn-capstone-project-help/" class="footer__link">BSN Capstone Project Help</a></li>
          <li><a href="/msn-capstone-project-help/" class="footer__link">MSN Capstone Project Help</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div class="footer__col">
        <h3 class="footer__col-heading">Resources</h3>
        <ul class="footer__links">
          <li><a href="/50-dnp-capstone-project-ideas/" class="footer__link">50 DNP Capstone Project Ideas</a></li>
          <li><a href="/60-dnp-picot-question-examples/" class="footer__link">60 DNP PICOT Question Examples</a></li>
          <li><a href="/dnp-capstone-project-examples/" class="footer__link">DNP Capstone Project Examples</a></li>
          <li><a href="/dnp-vs-phd-nursing/" class="footer__link">DNP vs PhD in Nursing</a></li>
