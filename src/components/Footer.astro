          <li><a href="/irb-protocol-dnp/" class="footer__link">IRB Protocol for DNP Projects</a></li>
        </ul>
      </div>

      <!-- Company + Policies -->
      <div class="footer__col">
        <h3 class="footer__col-heading">Company</h3>
        <ul class="footer__links">
          <li><a href="/about-us/" class="footer__link">About Us</a></li>
          <li><a href="/services/" class="footer__link">All Services</a></li>
          <li><a href="/samples/" class="footer__link">Writing Samples</a></li>
          <li><a href="/faq/" class="footer__link">FAQs</a></li>
          <li><a href="/contact-us/" class="footer__link">Contact Us</a></li>
